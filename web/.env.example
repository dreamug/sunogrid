# 复制为 .env 后按需填写。部署细节见仓库根 DEPLOY.md。

# —— 必需 ——
# MySQL 连接。库名(默认 hiphop_gen)由 prisma db push / migrate 建表。
DATABASE_URL="mysql://root:你的密码@127.0.0.1:3306/hiphop_gen"

# —— 生产必设 ——
# production 下登录 cookie 的 Secure 才会开(见 src/lib/auth.ts);next start 也按生产跑。
# 本地开发不用设(npm run dev 即 development)。
# NODE_ENV=production

# —— 可选 ——
# next start 监听端口(默认 3000;npm run dev 固定 3007,不读这个)。反代后随意。
# PORT=3000

# 乐器分离 sidecar 地址(见 src/lib/stems.ts);不部署 stem-service 时忽略。
# STEM_SERVICE_URL=http://127.0.0.1:8008

# §35 AI 提示词助手(gen-ta 角落 ✨):阿里云百炼 DashScope key(OpenAI 兼容接口)。
# 不填则 ✨ 浮层报"未配置",生成功能照常。
# DASHSCOPE_API_KEY=sk-xxxx
# QWEN_MODEL=qwen-flash                # 最便宜档;可换 qwen-turbo / qwen-plus
# DASHSCOPE_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1   # 国际账号换 dashscope-intl
