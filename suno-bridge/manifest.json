{
  "manifest_version": 3,
  "name": "Suno Bridge — Driver",
  "version": "0.2.0",
  "description": "嗅探 + 驱动 suno.com:在活会话里重放 generate/feed,并桥接本地 app(localhost)。",
  "permissions": ["storage", "tabs"],
  "host_permissions": [
    "https://suno.com/*",
    "https://*.suno.com/*",
    "https://*.suno.ai/*",
    "http://localhost/*",
    "http://127.0.0.1/*"
  ],
  "background": { "service_worker": "background.js" },
  "action": { "default_popup": "popup.html", "default_title": "Suno Bridge" },
  "content_scripts": [
    {
      "matches": ["https://suno.com/*", "https://*.suno.com/*", "https://*.suno.ai/*"],
      "js": ["interceptor.js"],
      "run_at": "document_start",
      "world": "MAIN"
    },
    {
      "matches": ["https://suno.com/*", "https://*.suno.com/*", "https://*.suno.ai/*"],
      "js": ["relay.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    },
    {
      "matches": ["http://localhost/*", "http://127.0.0.1/*"],
      "js": ["bridge.js"],
      "run_at": "document_start",
      "world": "ISOLATED"
    }
  ]
}
